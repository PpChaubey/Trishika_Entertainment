FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir kokoro-onnx soundfile numpy redis
COPY audio_server.py .
EXPOSE 3001
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:3001/audio/health')" || exit 1
CMD ["python3", "audio_server.py"]
